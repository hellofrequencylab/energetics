# Energetics environment variables. Copy to `.env.local` and fill in.

# --- AI narrative layer (optional) ------------------------------------------
# Enables the prose narrative over the deterministic synthesis (spec §9).
# Without it, all per-system computation and the convergence/tension map still
# work. Only the optional "Narrative" prose is disabled.
ANTHROPIC_API_KEY=

# --- Swiss Ephemeris data (optional) ----------------------------------------
# Absolute path to a directory of Swiss Ephemeris .se1 files for full
# sub-arcsecond precision. If unset, sweph falls back to the built-in Moshier
# ephemeris (~1 arcsec for modern dates), which is fine for development.
SE_EPHE_PATH=

# --- Supabase (optional until persistence is wired up) ----------------------
# The app computes charts without these; they enable auth + storage (spec §10).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key, server only. Enables the narrative cache: readings are stored
# once and reused instead of re-billing the model. Without it, readings still
# stream live, they just regenerate each time. NEVER expose this in a
# NEXT_PUBLIC_ variable or ship it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Distributed rate limit for the AI routes (optional) --------------------
# When set, the costly narrate routes share a per-IP limit across all serverless
# instances via Upstash Redis (REST). Without these, the limiter falls back to a
# per-instance in-memory window, which still blunts abuse. Server only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- AI cost safety (optional) ----------------------------------------------
# A hard global daily spend ceiling for the AI narrate routes, in USD. When set,
# each generation is pre-authorized against the day's total and refused (with a
# friendly message) once the ceiling would be passed. Unset means no global cap
# (per-user daily quotas still apply). Server only.
AI_DAILY_BUDGET_USD=
# Optional salt for hashing client IPs in the usage ledger (anonymous attribution
# is stored hashed, never as a raw IP). Any stable random string.
AI_USAGE_SALT=

# --- Cloudflare Turnstile (optional) ----------------------------------------
# Bot protection for anonymous (guest) sign-in and the public narrate routes.
# With no keys, the checks are skipped (per-user quotas still protect cost).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Stripe (subscriptions, optional until you sell Plus) --------------------
# Server only. Until these are set, the billing routes report "not set up yet"
# and everyone stays on the free tier. See docs/RUNBOOK.md for the full setup.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# The recurring price ids for OneSky Plus, created in the Stripe dashboard.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
